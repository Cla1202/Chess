<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/grigio_fumo"
    android:padding="8dp">

    <FrameLayout
        android:id="@+id/boardContainer"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <com.example.chess.util.SquareGridView
            android:id="@+id/chessGrid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:numColumns="8"
            android:stretchMode="columnWidth"
            android:background="@color/grigio_fumo"
            android:layout_margin="4dp" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="250dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="16dp">

        <TextView
            android:id="@+id/levelTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/caricamento"
            android:textColor="@color/gold"
            android:textStyle="bold"
            android:textSize="24sp"
            android:textAlignment="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tocca_a_te"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textAlignment="center"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/timerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/_00_30"
            android:textColor="@color/arancione"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <ProgressBar
            android:id="@+id/timerBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginBottom="24dp"
            android:progressTint="@color/arancione"
            android:progressBackgroundTint="@color/black_soft" />
        <Button
            android:id="@+id/hintButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="@string/aiuto" />

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/torna_indietro"
            android:src="@drawable/ic_arrow_back" />

    </LinearLayout>

</LinearLayout>